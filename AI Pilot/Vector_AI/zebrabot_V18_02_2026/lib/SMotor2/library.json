{
  "name": "SMotor2",
  "version": "1.0.0",
  "description": "ESP32 motor control library with encoder support",
  "keywords": ["motor", "encoder", "esp32", "driver"],
  "authors": [
    {
      "name": "Your Name",
      "email": "your.email@example.com"
    }
  ],
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],
  "dependencies": [
    {
      "name": "Wire"
    }
  ],
  "build": {
    "libArchive": true,
    "srcFilter": [
      "+<*.h>",
      "+<*.a>"
    ],
    "flags": [
      "-L .",
      "-lSMotor2"
    ]
  },
  "export": {
    "include": [
      "*.h",
      "*.a"
    ]
  }
}