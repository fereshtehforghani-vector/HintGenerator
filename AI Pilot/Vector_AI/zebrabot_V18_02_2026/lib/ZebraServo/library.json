{
  "name": "ZebraServo",
  "version": "1.0.0",
  "description": "ESP32 servo control library",
  "keywords": ["servo", "esp32", "motor"],
  "authors": [
    {
      "name": "Your Name",
      "email": "your.email@example.com"
    }
  ],
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],
  "dependencies": [
    {
      "name": "ESP32Servo"
    }
  ],
  "build": {
    "libArchive": true,
    "srcFilter": [
      "+<*.h>",
      "+<*.a>"
    ],
    "flags": [
      "-L .",
      "-lZebraServo"
    ]
  },
  "export": {
    "include": [
      "*.h",
      "*.a"
    ]
  }
}